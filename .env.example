# Base de datos — PostgreSQL instalado localmente (fuera de Docker)
# El contenedor web lo alcanza via host.docker.internal
# Para Azure PostgreSQL: cambiar HOST al endpoint del servidor administrado
POSTGRES_DB=plataforma_gestion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_en_produccion
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5434

# Django
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria-de-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Producción / Azure (solo aplican con DJANGO_SETTINGS_MODULE=config.settings.production)
# DJANGO_ALLOWED_HOSTS=miapp.azurewebsites.net
# CORS_ALLOWED_ORIGINS=https://miapp.azurewebsites.net
# CSRF_TRUSTED_ORIGINS=https://miapp.azurewebsites.net
